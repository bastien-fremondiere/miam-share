# Environment Variables for Miam Share
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Vercel Backend URL ────────────────────────────────────────────────────
# Development:  http://localhost:3000  (run `npm run api` in a separate terminal)
#               Android emulator: use http://10.0.2.2:3000
#               Physical device:  use your machine's LAN IP, e.g. http://192.168.1.x:3000
# Production:   your deployed Vercel project URL, e.g. https://miam-share.vercel.app
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── Android SDK ───────────────────────────────────────────────────────────
# Required for `expo run:android`. Set to your Android SDK path.
# Android emulator: use http://10.0.2.2:3000 for EXPO_PUBLIC_API_URL
ANDROID_HOME=/home/youruser/Android/Sdk

# ── Google OAuth (client-side) ───────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
#
# For Android device/emulator testing (recommended):
#   Create an ANDROID OAuth client in Google Console.
#   → Package name: fr.ohana.miam_share
#   → SHA-1: keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android -keypass android
#   → No redirect URI needed (uses com.googleusercontent.apps.XXXXX:/ automatically)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
#
# For iOS device/simulator testing:
#   Create an iOS OAuth client in Google Console.
#   → Bundle ID: fr.ohana.miamshare
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
#
# For web / Expo Go testing (optional):
#   Create a WEB OAuth client in Google Console.
#   → Authorized redirect URIs: http://localhost:8081
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── Server-Side Only (set in Vercel Dashboard → Settings → Environment Variables) ──
# These are NOT prefixed with EXPO_PUBLIC_ — they never reach the mobile app.
#
# GEMINI_API_KEY=your_gemini_api_key_here   (Vercel serverless functions only)
# POSTGRES_URL=...                          (auto-set by Vercel when you add a Postgres DB)
# POSTGRES_URL_NON_POOLING=...             (auto-set by Vercel)
